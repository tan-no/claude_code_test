{
  "name": "sample-repo",
  "version": "1.0.0",
  "description": "Claude Code検証用サンプルプロジェクト",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node src/index.ts",
    "server": "ts-node src/server.ts",
    "build": "tsc",
    "test": "jest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "gif-encoder-2": "^1.0.5",
    "html2canvas": "^1.4.1",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "./tsconfig.test.json"
        }
      ]
    }
  }
}
